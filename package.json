{
  "name": "agentlayer",
  "version": "0.1.0",
  "description": "Intelligent context routing for AI coding agents",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "agentlayer": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "RELEASING.md"
  ],
  "keywords": [
    "ai",
    "agents",
    "cli",
    "mcp",
    "context",
    "developer-tools"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc --project tsconfig.json",
    "check": "npm run typecheck && npm run test",
    "dev": "npm run build && node dist/cli/index.js",
    "pack:check": "npm pack --dry-run",
    "pretest": "npm run build",
    "prepack": "npm run build",
    "release:check": "npm run typecheck && npm test && npm run smoke && npm run pack:check",
    "smoke": "node dist/cli/index.js --help",
    "test": "node --test test/**/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "glob": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.21",
    "typescript": "^5.5.0"
  }
}
