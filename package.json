{
  "name": "@iamsyr/agentmind",
  "version": "0.2.0",
  "description": "Intelligent context routing for AI coding agents",
  "license": "MIT",
  "author": "iamsyr",
  "type": "module",
  "homepage": "https://github.com/doanbactam/agentmind#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doanbactam/agentmind.git",
    "directory": "."
  },
  "bugs": {
    "url": "https://github.com/doanbactam/agentmind/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "agentmind": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "RELEASING.md"
  ],
  "keywords": [
    "ai",
    "agents",
    "cli",
    "mcp",
    "context",
    "developer-tools"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc --project tsconfig.json",
    "check": "npm run typecheck && npm run test",
    "dev": "npm run build && node dist/cli/index.js",
    "pack:check": "npm pack --dry-run",
    "pretest": "npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run release:check",
    "release:check": "npm run typecheck && npm test && npm run smoke && npm run pack:check",
    "smoke": "node dist/cli/index.js --help",
    "test": "node --test test/**/*.test.mjs",
    "test:verbose": "node --test test/**/*.test.mjs --test-reporter spec",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "glob": "^10.0.0",
    "ora": "^8.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.21",
    "@types/sql.js": "^1.4.11",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
